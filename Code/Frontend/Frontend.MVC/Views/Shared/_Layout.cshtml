<!DOCTYPE html>
<html lang="es-CR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — PROCOMER Calendarización</title>
    <!-- Bootstrap 5.3 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        /* ── Variables de marca PROCOMER ── */
        :root {
            --brand: #0c7c59;
            --brand-dark: #095c42;
            --brand-soft: #e7f4ef;
            --radius: .5rem;
        }
        body { padding-top: 60px; padding-bottom: 56px; background: #f6f8f7; }
        /* Botones de marca */
        .btn-brand { background-color: var(--brand); color: #fff; border-color: var(--brand); }
        .btn-brand:hover { background-color: var(--brand-dark); border-color: var(--brand-dark); color: #fff; }
        .btn-outline-brand { color: var(--brand); border-color: var(--brand); }
        .btn-outline-brand:hover { background-color: var(--brand); color: #fff; }
        .bg-brand { background-color: var(--brand) !important; }
        .text-brand { color: var(--brand) !important; }
        /* Navbar */
        .navbar-brand-text { font-weight: 700; font-size: 1.15rem; letter-spacing: -.3px; }
        /* Cards */
        .card { border: 0; border-radius: var(--radius); box-shadow: 0 1px 6px rgba(0,0,0,.07); }
        /* Pills activas */
        .nav-pills .nav-link.active { background-color: var(--brand); }
        /* Stat cards */
        .stat-card .icon { width: 46px; height: 46px; background: var(--brand-soft); border-radius: var(--radius); display:flex; align-items:center; justify-content:center; }
        /* Tablas */
        .table thead th { text-transform: uppercase; font-size: .78rem; letter-spacing: .05em; color: #6c757d; }
        /* Chips de idioma */
        .lang-chip { font-size: .72rem; padding: .15em .5em; }
        /* Timeline */
        .timeline-dot { width: 12px; height: 12px; border-radius: 50%; background: var(--brand); flex-shrink: 0; }
        .timeline-line { width: 2px; background: var(--brand-soft); flex-grow: 1; min-height: 24px; margin: 0 auto; }
        /* Skeleton */
        .skeleton { background: linear-gradient(90deg, #e9ecef 25%, #dee2e6 50%, #e9ecef 75%); background-size: 400% 100%; animation: sk 1.2s infinite; border-radius: 4px; height: 16px; }
        @@keyframes sk { 0%{background-position:100% 50%} 100%{background-position:0 50%} }
        /* Empty state */
        .empty-state { padding: 2.5rem 1rem; text-align: center; color: #6c757d; }
        .empty-state i { font-size: 2.5rem; display: block; margin-bottom: .5rem; }
        /* Táctil mínimo */
        .min-touch { min-width: 44px; min-height: 44px; }
        footer { position: fixed; bottom: 0; left: 0; right: 0; z-index: 1020; background: #fff; border-top: 1px solid #dee2e6; padding: .6rem 0; }
        /* SPA page transitions */
        .page { display: none; animation: fade .18s ease; }
        .page.active { display: block; }
        @@keyframes fade { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:none} }
        @@media (prefers-reduced-motion: reduce) { .page { animation: none; } .skeleton { animation: none; } }
    </style>
</head>
<body>
    <!-- Navbar fija -->
    <nav class="navbar navbar-expand-lg bg-brand fixed-top shadow-sm" data-bs-theme="dark">
        <div class="container-fluid">
            <a class="navbar-brand navbar-brand-text text-white" href="#" onclick="go('inicio')">
                <i class="bi bi-calendar2-check me-1"></i>PROCOMER
            </a>
            <button class="navbar-toggler min-touch" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav ms-auto gap-1" id="navItems">
                    <li class="nav-item"><a class="nav-link active" href="#" id="nav-inicio" onclick="go('inicio')"><i class="bi bi-house me-1"></i>Inicio</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" id="nav-inversores" onclick="go('inversores')"><i class="bi bi-person-badge me-1"></i>Inversores</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" id="nav-participantes" onclick="go('participantes')"><i class="bi bi-people me-1"></i>Participantes</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" id="nav-agenda" onclick="go('agenda')"><i class="bi bi-magic me-1"></i>Generar Agenda</a></li>
                    <li class="nav-item"><a class="nav-link" href="#" id="nav-agendas" onclick="go('agendas')"><i class="bi bi-list-check me-1"></i>Agendas</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="container-fluid px-3 px-lg-4">
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="pt-2 pb-1">
            <ol class="breadcrumb small mb-0" id="breadcrumb">
                <li class="breadcrumb-item"><a href="#" onclick="go('inicio')">Inicio</a></li>
                <li class="breadcrumb-item active" id="breadcrumb-current"></li>
            </ol>
        </nav>

        <!-- Páginas SPA -->
        @RenderBody()
    </div>

    <footer>
        <div class="container-fluid px-3 px-lg-4 text-center text-muted small">
            © 2026 PROCOMER — Sistema de Calendarización de Inversores
        </div>
    </footer>

    <!-- Toast container -->
    <div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999" id="toastContainer"></div>

    <!-- Bootstrap 5.3 JS Bundle CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery 3.x CDN -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <script>
    /* ── Configuración de URLs de microservicios ── */
    const CATALOGO_URL = '@(ViewBag.CatalogoUrl ?? "https://localhost:5001")';
    const AGENDAS_URL  = '@(ViewBag.AgendasUrl ?? "https://localhost:5002")';

    /* ── Router SPA ── */
    const pageNames = {
        inicio: 'Inicio', inversores: 'Inversores',
        participantes: 'Participantes', agenda: 'Generar Agenda', agendas: 'Agendas'
    };

    function go(page) {
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        const el = document.getElementById('page-' + page);
        if (el) el.classList.add('active');
        document.querySelectorAll('#navItems .nav-link').forEach(a => a.classList.remove('active'));
        const nav = document.getElementById('nav-' + page);
        if (nav) nav.classList.add('active');
        const bc = document.getElementById('breadcrumb-current');
        if (bc) {
            bc.textContent = pageNames[page] || page;
            bc.parentElement.style.display = page === 'inicio' ? 'none' : '';
        }
        window.scrollTo({ top: 0, behavior: 'smooth' });
        // Cargar datos de la página si tiene función de carga
        if (typeof window['load_' + page] === 'function') window['load_' + page]();
    }

    /* ── Toast helper ── */
    function showToast(msg, type = 'success') {
        const icons = { success: 'check-circle-fill', error: 'x-circle-fill', info: 'info-circle-fill', warning: 'exclamation-triangle-fill' };
        const colors = { success: 'text-success', error: 'text-danger', info: 'text-info', warning: 'text-warning' };
        const id = 'toast-' + Date.now();
        const html = `<div id="${id}" class="toast align-items-center border-0 shadow-sm" role="alert">
            <div class="d-flex">
                <div class="toast-body d-flex align-items-center gap-2">
                    <i class="bi bi-${icons[type]} ${colors[type]}"></i>${msg}
                </div>
                <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
            </div></div>`;
        $('#toastContainer').append(html);
        const el = document.getElementById(id);
        const t = new bootstrap.Toast(el, { delay: 3200 });
        t.show();
        el.addEventListener('hidden.bs.toast', () => el.remove());
    }

    /* ── Inicio ── */
    document.addEventListener('DOMContentLoaded', () => {
        go('inicio');
        // Ocultar breadcrumb en inicio
        document.getElementById('breadcrumb').style.display = 'none';
    });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

